# utrains API keys - copy this file to ".env" (here) or to ~/.utrains/.env
#   cp .env.example .env       # then fill in the keys you have
#
# utrains loads .env automatically on startup. Keys you don't have can be left
# blank or deleted. Local Ollama models need no key at all.

# Anthropic Claude  (used for any model whose name starts with "claude-")
ANTHROPIC_API_KEY=

# OpenAI GPT        (used for any model whose name starts with "gpt-")
OPENAI_API_KEY=

# Optional: override which model utrains uses by default
# UTRAINS_MODEL=claude-opus-4-8
